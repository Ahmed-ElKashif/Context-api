      "name": "Auth",
      "item": [
        {
          "name": "Post Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// This script runs automatically after a successful login\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "if (response.success && response.token) {\r",
                  "    pm.environment.set(\"token\", response.token);\r",
                  "    console.log(\"Token saved automatically!\");\r",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"ahmed@company.com\",\r\n  \"password\": \"Password123!\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
