# ==========================================
# 🌐 SERVER CONFIGURATION
# ==========================================
# (Set to 'production' when deploying to Vercel/Render/Heroku)
NODE_ENV=development

PORT=5000

# The URL of your React frontend (Used to configure CORS security)
CLIENT_URL=http://localhost:3000

# ==========================================
# 💾 DATABASE (MongoDB Atlas)
# ==========================================
# Your MongoDB connection string. Ensure your IP address is whitelisted in Atlas!
MONGO_URI=mongodb://your_username:your_password@your_cluster_url/?ssl=true&replicaSet=atlas-xxx&authSource=admin&appName=Context

# ==========================================
# 🔐 AUTHENTICATION (JSON Web Tokens)
# ==========================================
# A long, random cryptographic string used to sign user sessions. 
# (Generate one using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=your_super_secret_jwt_key_here
# How long before the user has to log in again (e.g., 7d, 24h)
JWT_EXPIRES_IN=30d

# ==========================================
# ☁️ CLOUD STORAGE (Cloudinary)
# ==========================================
# Used for storing uploaded PDFs, Images, and Word Docs.
# Get these from your Cloudinary Dashboard -> Account Details.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==========================================
# 🧠 AI ORCHESTRATION (OpenAI)
# ==========================================
# Powers the Document Summarization, Tag Extraction, Semantic Folder Routing,
# RAG Chat Interface, and Vector Database Embeddings (text-embedding-3-small).
OPENAI_API_KEY=your_openai_api_key_here
# Max Daily Budget
AI_DAILY_TOKEN_BUDGET=1000000


# ==========================================
# ⚡ HIGH-SPEED AI ANALYSIS (Groq)
# ==========================================
# Powers the ultra-fast Document Comparison engine.
GROQ_API_KEY=your_groq_api_key_here
# The specific model to use for the DeepThinker comparison service
GROQ_VERSATILE_COMPARISON_MODEL=llama-3.3-70b-versatile
GROQ_INSTANT_COMPARISON_MODEL=llama-3.1-8b-instant
GROQ_VIRTUAL_CORTEX_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


#Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM=your_smtp_from_email@gmail.com

FRONTEND_URL=http://localhost:5173